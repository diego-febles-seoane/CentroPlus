<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="es.ies.puerto.controller.MainController" minHeight="700" minWidth="900" prefHeight="800" prefWidth="1200">
    
    <!-- Barra lateral izquierda -->
    <left>
        <VBox style="-fx-background-color: #0f172a; -fx-min-width: 240; -fx-max-width: 240;" spacing="0">
            <!-- Logo y título -->
            <VBox style="-fx-background-color: #1e293b; -fx-padding: 25 20;" spacing="8">
                <Label text="CentroPlus" style="-fx-text-fill: #ffffff; -fx-font-size: 26; -fx-font-weight: bold;"/>
                <Label text="Gestión Integral" style="-fx-text-fill: #94a3b8; -fx-font-size: 12;"/>
            </VBox>
            
            <!-- Menú de navegación -->
            <VBox style="-fx-padding: 20 0;" spacing="5">
                <Button text="🏠  Inicio" onAction="#showMain" maxWidth="Infinity" style="-fx-background-color: #1e293b; -fx-text-fill: #e2e8f0; -fx-font-size: 15; -fx-alignment: CENTER_LEFT; -fx-padding: 15 20; -fx-background-radius: 0;"/>
                <Button text="📋  Actividades" onAction="#showActividades" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-font-size: 15; -fx-alignment: CENTER_LEFT; -fx-padding: 15 20; -fx-background-radius: 0;"/>
                <Button text="📅  Reservas" onAction="#showReservas" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-font-size: 15; -fx-alignment: CENTER_LEFT; -fx-padding: 15 20; -fx-background-radius: 0;"/>
                <Button text="⚠️  Incidencias" onAction="#showIncidencias" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-font-size: 15; -fx-alignment: CENTER_LEFT; -fx-padding: 15 20; -fx-background-radius: 0;"/>
                <Button text="👥  Usuarios" onAction="#showUsuarios" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-font-size: 15; -fx-alignment: CENTER_LEFT; -fx-padding: 15 20; -fx-background-radius: 0;"/>
            </VBox>
            
            <!-- Espaciador -->
            <Region VBox.vgrow="ALWAYS"/>
            
            <!-- Pie de la barra lateral -->
            <VBox style="-fx-padding: 20; -fx-background-color: #1e293b;" spacing="10">
                <Separator style="-fx-background-color: #334155;"/>
                <Label text="Versión 1.0.0" style="-fx-text-fill: #64748b; -fx-font-size: 12;"/>
                <Label text="© 2024 CentroPlus" style="-fx-text-fill: #64748b; -fx-font-size: 11;"/>
            </VBox>
        </VBox>
    </left>
    
    <!-- Área de contenido principal -->
    <center>
        <VBox style="-fx-background-color: #f8fafc;" spacing="0">
            <!-- Barra superior del contenido -->
            <HBox style="-fx-background-color: #ffffff; -fx-padding: 15 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 1);" alignment="CENTER_LEFT" spacing="20">
                <Label text="Panel de Control" style="-fx-text-fill: #1e293b; -fx-font-size: 22; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Bienvenido/a" style="-fx-text-fill: #64748b; -fx-font-size: 14;"/>
            </HBox>
            
            <!-- Contenedor principal del contenido -->
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" style="-fx-background-color: #f8fafc; -fx-padding: 30;"/>
        </VBox>
    </center>
    
</BorderPane>
