<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="es.ies.puerto.controller.MainController" minHeight="1000" minWidth="600" prefHeight="1000" prefWidth="600">
    
    <!-- Barra lateral izquierda (ahora superior para vertical) -->
    <top>
        <VBox style="-fx-background-color: #0f172a;" spacing="0">
            <!-- Logo y título -->
            <VBox style="-fx-background-color: #1e293b; -fx-padding: 15 20;" spacing="5" alignment="CENTER">
                <Label text="CentroPlus" style="-fx-text-fill: #ffffff; -fx-font-size: 22; -fx-font-weight: bold;"/>
                <Label text="Gestión Integral" style="-fx-text-fill: #94a3b8; -fx-font-size: 12;"/>
            </VBox>
            
            <!-- Menú de navegación horizontal -->
            <HBox style="-fx-padding: 10 15;" spacing="10" alignment="CENTER">
                <Button text="🏠" onAction="#showMain" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: #1e293b; -fx-text-fill: #e2e8f0; -fx-font-size: 14; -fx-alignment: CENTER; -fx-padding: 10 15; -fx-background-radius: 8;"/>
                <Button text="📋" onAction="#showActividades" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-font-size: 14; -fx-alignment: CENTER; -fx-padding: 10 15; -fx-background-radius: 8;"/>
                <Button text="📅" onAction="#showReservas" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-font-size: 14; -fx-alignment: CENTER; -fx-padding: 10 15; -fx-background-radius: 8;"/>
                <Button text="⚠️" onAction="#showIncidencias" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-font-size: 14; -fx-alignment: CENTER; -fx-padding: 10 15; -fx-background-radius: 8;"/>
                <Button text="👥" onAction="#showUsuarios" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-font-size: 14; -fx-alignment: CENTER; -fx-padding: 10 15; -fx-background-radius: 8;"/>
            </HBox>
        </VBox>
    </top>
    
    <!-- Área de contenido principal -->
    <center>
        <VBox style="-fx-background-color: #f8fafc;" spacing="0">
            <!-- Contenedor principal del contenido -->
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" style="-fx-background-color: #f8fafc; -fx-padding: 15;"/>
        </VBox>
    </center>
    
</BorderPane>