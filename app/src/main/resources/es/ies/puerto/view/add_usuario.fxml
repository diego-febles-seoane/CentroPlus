<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml" fx:controller="es.ies.puerto.controller.AddUsuarioController" style="-fx-padding: 20;">
    <Label text="Añadir Nuevo Usuario" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
    
    <GridPane hgap="10" vgap="10">
        <Label text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="idField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        
        <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="nombreField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        
        <Label text="DNI:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="dniField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        
        <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        
        <Label text="Teléfono:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="telefonoField" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        
        <Label text="Tipo Usuario:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <ComboBox fx:id="tipoCombo" GridPane.columnIndex="1" GridPane.rowIndex="5" maxWidth="Infinity"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#cancelar"/>
        <Button text="Guardar" onAction="#guardar" style="-fx-background-color: #2ecc71; -fx-text-fill: white;"/>
    </HBox>
</VBox>
