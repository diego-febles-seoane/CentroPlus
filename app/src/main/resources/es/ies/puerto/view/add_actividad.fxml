<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml" fx:controller="es.ies.puerto.controller.AddActividadController" style="-fx-padding: 25; -fx-background-color: #f8fafc;">
    <VBox spacing="5">
        <Label text="Nueva Actividad" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
        <Label text="Formulario para crear una nueva actividad" style="-fx-font-size: 14; -fx-text-fill: #64748b;"/>
    </VBox>
    
    <GridPane hgap="15" vgap="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 3, 3);">
        <Label text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #475569; -fx-font-size: 14;"/>
        <TextField fx:id="idField" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-background-color: #f1f5f9; -fx-background-radius: 8; -fx-padding: 10 15; -fx-font-size: 13;"/>
        
        <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #475569; -fx-font-size: 14;"/>
        <TextField fx:id="nombreField" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-background-color: #f1f5f9; -fx-background-radius: 8; -fx-padding: 10 15; -fx-font-size: 13;"/>
        
        <Label text="Tipo:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #475569; -fx-font-size: 14;"/>
        <TextField fx:id="tipoField" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-background-color: #f1f5f9; -fx-background-radius: 8; -fx-padding: 10 15; -fx-font-size: 13;"/>
        
        <Label text="Duración (min):" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: #475569; -fx-font-size: 14;"/>
        <TextField fx:id="duracionField" GridPane.columnIndex="1" GridPane.rowIndex="3" style="-fx-background-color: #f1f5f9; -fx-background-radius: 8; -fx-padding: 10 15; -fx-font-size: 13;"/>
        
        <Label text="Precio:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-text-fill: #475569; -fx-font-size: 14;"/>
        <TextField fx:id="precioField" GridPane.columnIndex="1" GridPane.rowIndex="4" style="-fx-background-color: #f1f5f9; -fx-background-radius: 8; -fx-padding: 10 15; -fx-font-size: 13;"/>
        
        <Label text="Plazas Máximas:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-text-fill: #475569; -fx-font-size: 14;"/>
        <TextField fx:id="maxField" GridPane.columnIndex="1" GridPane.rowIndex="5" style="-fx-background-color: #f1f5f9; -fx-background-radius: 8; -fx-padding: 10 15; -fx-font-size: 13;"/>
    </GridPane>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="❌ Cancelar" onAction="#cancelar" style="-fx-background-color: #e2e8f0; -fx-text-fill: #1e293b; -fx-font-size: 13; -fx-font-weight: bold; -fx-padding: 10 22; -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Button text="✅ Guardar" onAction="#guardar" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-padding: 10 22; -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>
</VBox>
