<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml" fx:controller="es.ies.puerto.controller.AddActividadController" style="-fx-padding: 20;">
    <Label text="Añadir Nueva Actividad" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
    
    <GridPane hgap="10" vgap="10">
        <Label text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="idField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        
        <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="nombreField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        
        <Label text="Tipo:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="tipoField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        
        <Label text="Duración (min):" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="duracionField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        
        <Label text="Precio:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="precioField" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        
        <Label text="Plazas Máximas:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <TextField fx:id="maxField" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#cancelar"/>
        <Button text="Guardar" onAction="#guardar" style="-fx-background-color: #2ecc71; -fx-text-fill: white;"/>
    </HBox>
</VBox>
