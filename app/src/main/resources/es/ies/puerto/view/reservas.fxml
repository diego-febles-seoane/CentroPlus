<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml" fx:controller="es.ies.puerto.controller.ReservasController" style="-fx-padding: 25; -fx-background-color: #f8fafc;">
    <VBox spacing="5">
        <Label text="Reservas" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
        <Label text="Gestión de todas las reservas de actividades" style="-fx-font-size: 14; -fx-text-fill: #64748b;"/>
    </VBox>
    
    <TableView fx:id="reservasTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 3, 3);">
        <columns>
            <TableColumn fx:id="colIdReserva" text="ID Reserva" prefWidth="120"/>
            <TableColumn fx:id="colIdUsuario" text="ID Usuario" prefWidth="120"/>
            <TableColumn fx:id="colIdActividad" text="ID Actividad" prefWidth="130"/>
            <TableColumn fx:id="colFecha" text="Fecha" prefWidth="180"/>
            <TableColumn fx:id="colEstado" text="Estado" prefWidth="120"/>
        </columns>
    </TableView>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="❌ Cancelar Reserva" onAction="#cancelarReserva" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-padding: 10 22; -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Button text="➕ Nueva Reserva" onAction="#nuevaReserva" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-padding: 10 22; -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>
</VBox>
