<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" prefWidth="900" prefHeight="700">
    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #1e3a8a, #3b82f6); -fx-padding: 30 40;" spacing="10">
            <Label text="CentroPlus" style="-fx-text-fill: white; -fx-font-size: 32; -fx-font-weight: bold;"/>
            <Label text="Plataforma de Gestión Académica y Deportiva" style="-fx-text-fill: #dbeafe; -fx-font-size: 14;"/>
        </VBox>
    </top>
    
    <center>
        <VBox spacing="25" style="-fx-background-color: #f1f5f9; -fx-padding: 35;">
            <VBox alignment="CENTER" spacing="15">
                <Label text="¡Bienvenido/a al Panel de Control!" style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Gestione de forma eficiente sus actividades, reservas, incidencias y usuarios desde una única plataforma" style="-fx-font-size: 15; -fx-text-fill: #475569; -fx-text-alignment: center; -fx-wrap-text: true; -fx-max-width: 700;"/>
            </VBox>
            
            <GridPane hgap="20" vgap="20" style="-fx-padding: 15 0;">
                <VBox style="-fx-background-color: linear-gradient(145deg, #ffffff, #e0f2fe); -fx-background-radius: 16; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.2), 12, 0, 4, 6);" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="📋" style="-fx-font-size: 48;"/>
                    <Label text="Actividades" style="-fx-text-fill: #1e293b; -fx-font-size: 18; -fx-font-weight: bold; -fx-padding: 12 0 5 0;"/>
                    <Label text="Administrar todas las actividades disponibles" style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-padding: 0 0 15 0;"/>
                    <Button text="Ver actividades" onAction="#showActividades" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </VBox>
                
                <VBox style="-fx-background-color: linear-gradient(145deg, #ffffff, #d1fae5); -fx-background-radius: 16; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(16,185,129,0.2), 12, 0, 4, 6);" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="📅" style="-fx-font-size: 48;"/>
                    <Label text="Reservas" style="-fx-text-fill: #1e293b; -fx-font-size: 18; -fx-font-weight: bold; -fx-padding: 12 0 5 0;"/>
                    <Label text="Reservar plaza en las actividades" style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-padding: 0 0 15 0;"/>
                    <Button text="Ver reservas" onAction="#showReservas" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </VBox>
                
                <VBox style="-fx-background-color: linear-gradient(145deg, #ffffff, #fee2e2); -fx-background-radius: 16; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(239,68,68,0.2), 12, 0, 4, 6);" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="⚠️" style="-fx-font-size: 48;"/>
                    <Label text="Incidencias" style="-fx-text-fill: #1e293b; -fx-font-size: 18; -fx-font-weight: bold; -fx-padding: 12 0 5 0;"/>
                    <Label text="Reportar y gestionar incidencias" style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-padding: 0 0 15 0;"/>
                    <Button text="Ver incidencias" onAction="#showIncidencias" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </VBox>
                
                <VBox style="-fx-background-color: linear-gradient(145deg, #ffffff, #ede9fe); -fx-background-radius: 16; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.2), 12, 0, 4, 6);" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="👥" style="-fx-font-size: 48;"/>
                    <Label text="Usuarios" style="-fx-text-fill: #1e293b; -fx-font-size: 18; -fx-font-weight: bold; -fx-padding: 12 0 5 0;"/>
                    <Label text="Gestionar los usuarios del sistema" style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-padding: 0 0 15 0;"/>
                    <Button text="Ver usuarios" onAction="#showUsuarios" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </VBox>
            </GridPane>
            
            <VBox spacing="12" style="-fx-padding: 15 0;">
                <Separator style="-fx-background-color: #cbd5e1;"/>
                <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10 0;">
                    <Label text="⚡ Rápido y eficiente" style="-fx-text-fill: #64748b; -fx-font-size: 13;"/>
                    <Label text="🔒 Seguro" style="-fx-text-fill: #64748b; -fx-font-size: 13;"/>
                    <Label text="📱 Fácil de usar" style="-fx-text-fill: #64748b; -fx-font-size: 13;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
    
    <bottom>
        <VBox style="-fx-background-color: #e2e8f0; -fx-padding: 18 40;">
            <Label text="© 2024 CentroPlus - Todos los derechos reservados" style="-fx-text-fill: #475569; -fx-font-size: 12; -fx-alignment: center;"/>
        </VBox>
    </bottom>
</BorderPane>
