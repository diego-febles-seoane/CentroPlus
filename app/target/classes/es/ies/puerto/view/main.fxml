<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="es.ies.puerto.controller.MainController" minHeight="600" minWidth="360" prefHeight="800" prefWidth="400" spacing="10">
    
    <!-- Barra superior -->
    <HBox style="-fx-background-color: #2c3e50; -fx-padding: 15;">
        <Label text="CentroPlus Connect" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
    </HBox>

    <!-- Botones de navegación (superior) -->
    <VBox style="-fx-padding: 10;" spacing="10">
        <Button text="Actividades" onAction="#showActividades" maxWidth="Infinity" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14; -fx-padding: 12;"/>
        <Button text="Reservas" onAction="#showReservas" maxWidth="Infinity" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-size: 14; -fx-padding: 12;"/>
        <Button text="Incidencias" onAction="#showIncidencias" maxWidth="Infinity" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 14; -fx-padding: 12;"/>
        <Button text="Usuarios" onAction="#showUsuarios" maxWidth="Infinity" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-size: 14; -fx-padding: 12;"/>
    </VBox>

    <!-- Contenido -->
    <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS">
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 20;">
            <Label text="Bienvenido" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
            <Label text="Pulsa un botón para empezar" style="-fx-font-size: 14;"/>
        </VBox>
    </StackPane>

    <!-- Barra de estado -->
    <Label fx:id="statusLabel" text="Listo" style="-fx-padding: 10; -fx-background-color: #ecf0f1;"/>
</VBox>
