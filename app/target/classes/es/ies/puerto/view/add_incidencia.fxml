<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml" fx:controller="es.ies.puerto.controller.AddIncidenciaController" style="-fx-padding: 20;">
    <Label text="Registrar Incidencia" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
    
    <GridPane hgap="10" vgap="10">
        <Label text="ID Incidencia:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="idIncidenciaField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        
        <Label text="ID Usuario:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="idUsuarioField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        
        <Label text="Asunto:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="asuntoField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        
        <Label text="Descripción:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextArea fx:id="descripcionArea" GridPane.columnIndex="1" GridPane.rowIndex="3" prefRowCount="3"/>
        
        <Label text="Estado:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <ComboBox fx:id="estadoCombo" GridPane.columnIndex="1" GridPane.rowIndex="4" maxWidth="Infinity"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#cancelar"/>
        <Button text="Guardar" onAction="#guardar" style="-fx-background-color: #2ecc71; -fx-text-fill: white;"/>
    </HBox>
</VBox>
